# Credenciales para tests Playwright. Copia este fichero como .env y rellena los valores.
# NUNCA subas .env al repo.
# IMPORTANTE: valores que contengan # deben ir entre comillas dobles (ej: PASSWORD="abc#123")
# porque dotenv interpreta # sin comillas como inicio de comentario.

# ── Supabase (solo para scripts de provisioning) ──────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=eyJ...tu_service_role_key_aqui

# ── Test de aislamiento RLS (npm run test:e2e) ────────────────────────────────
# Variable legada que usa aislamiento-centros.spec.js — apunta a la cuenta de test Agora
AGORA_ADMIN_EMAIL=test-admin-agora@didactia.eu
AGORA_ADMIN_PASSWORD=tu_contraseña_aqui

# ── Usuarios de test RLS — 4 cuentas dedicadas (creadas con setup:test-users) ─
TEST_ADMIN_AGORA_EMAIL=test-admin-agora@didactia.eu
TEST_ADMIN_AGORA_PASSWORD=tu_contraseña_aqui

TEST_PROF_AGORA_EMAIL=test-prof-agora@didactia.eu
TEST_PROF_AGORA_PASSWORD=tu_contraseña_aqui

TEST_ADMIN_BUNOL_EMAIL=test-admin-bunol@didactia.eu
TEST_ADMIN_BUNOL_PASSWORD=tu_contraseña_aqui

TEST_PROF_BUNOL_EMAIL=test-prof-bunol@didactia.eu
TEST_PROF_BUNOL_PASSWORD=tu_contraseña_aqui

# ── Test de privacidad RLS familia (npm run test:e2e -- --grep familia) ───────
# Cuenta con rol=familia vinculada a al menos 1 alumno en Agora Lledó.
# Crear desde panel Usuarios → Invitar → rol: Familia → vincular alumno.
TEST_FAMILIA_AGORA_EMAIL=test-familia-agora@didactia.eu
TEST_FAMILIA_AGORA_PASSWORD=tu_contraseña_aqui

# ── Pre-demo check — admin de IES Demo (npm run test:demo) ────────────────────
DEMO_ADMIN_EMAIL=demo@didactia.eu
DEMO_ADMIN_PASSWORD=tu_contraseña_aqui
