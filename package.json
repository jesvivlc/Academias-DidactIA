{
  "name": "didactia",
  "version": "1.0.0",
  "description": "DidactIA — plataforma educativa SaaS multi-tenant",
  "scripts": {
    "test:e2e": "playwright test tests/aislamiento-centros.spec.js",
    "test:rls-familia": "playwright test tests/rls-familia.spec.js",
    "test:demo": "playwright test tests/demo-check.spec.js",
    "setup:test-users": "node scripts/setup-test-users.js",
    "verify:columns": "node scripts/verify-columns.js",
    "verify:planner": "node scripts/verify-hard-constraints.js && node scripts/verify-sin-profesor.js && node scripts/verify-tablero-dnd.js",
    "fuzz:planner": "node scripts/planner-fuzz/run.js",
    "verify:planner-fuzz": "node scripts/planner-fuzz/selftest.js && node scripts/planner-fuzz/run.js --iters=600 --profile=realistic --bail"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "dotenv": "^16.4.5",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5"
  }
}
